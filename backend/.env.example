# Server Configuration
  HOST=0.0.0.0
  PORT=3000
  NODE_ENV=development
  LOG_LEVEL=INFO

  # JWT Configuration
  JWT_SECRET=change-this-to-a-random-string-with-at-least-32-chars
  JWT_EXPIRES_IN=24h

  # Authentication
  API_TOKENS=

  # CORS Configuration
  CORS_ORIGIN=*

  # Docker Configuration
  DOCKER_SOCKET_PATH=/var/run/docker.sock

  # WebSocket Configuration
  WS_PING_INTERVAL=30000
  WS_PING_TIMEOUT=5000

  # Rate Limiting
  RATE_LIMIT_WINDOW_MS=60000
  RATE_LIMIT_MAX_REQUESTS=100

  # System Stats
  STATS_UPDATE_INTERVAL=5000
  STATS_HISTORY_SIZE=100

  # Log Streaming
  LOG_BUFFER_SIZE=100
  LOG_FLUSH_INTERVAL=100

  # Terminal
  TERMINAL_IDLE_TIMEOUT=600000
  TERMINAL_MAX_SESSIONS=10

  # Tunnel
  TUNNEL_PROVIDER=tailscale
  TUNNEL_STATUS_POLL_INTERVAL=5000

  # Tailscale CLI
  TAILSCALE_CLI_PATH=tailscale
  TAILSCALE_AUTH_KEY=
  TAILSCALE_HOSTNAME=container-manager
  TAILSCALE_ACCEPT_DNS=false
  TAILSCALE_ACCEPT_ROUTES=false
  TAILSCALE_ADVERTISE_TAGS=tag:containermaster

  # Tailscale API - opcional neste sprint
  TAILSCALE_API_BASE_URL=https://api.tailscale.com
  TAILSCALE_API_TOKEN=
  TAILSCALE_TAILNET=
