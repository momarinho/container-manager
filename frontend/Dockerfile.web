FROM node:20-slim AS builder

WORKDIR /app/frontend

ARG EXPO_PUBLIC_DEFAULT_API_URL=http://localhost:3000
ARG EXPO_PUBLIC_RELEASE_CHANNEL=local
ARG EXPO_PUBLIC_COMMIT_SHA=local
ARG EXPO_PUBLIC_APP_VERSION_LABEL=

ENV PATH="/app/frontend/node_modules/.bin:$PATH"
ENV CI=1
ENV EXPO_NO_TELEMETRY=1
ENV EXPO_PUBLIC_DEFAULT_API_URL=$EXPO_PUBLIC_DEFAULT_API_URL
ENV EXPO_PUBLIC_RELEASE_CHANNEL=$EXPO_PUBLIC_RELEASE_CHANNEL
ENV EXPO_PUBLIC_COMMIT_SHA=$EXPO_PUBLIC_COMMIT_SHA
ENV EXPO_PUBLIC_APP_VERSION_LABEL=$EXPO_PUBLIC_APP_VERSION_LABEL

COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci

COPY frontend /app/frontend
COPY shared /app/shared

RUN npm run export:web

FROM node:20-slim AS runtime

WORKDIR /app

ENV NODE_ENV=production

RUN npm install --global serve

COPY --from=builder /app/frontend/dist /app/dist

EXPOSE 8081

CMD ["serve", "-s", "/app/dist", "-l", "8081"]
