BACKEND_HOST_PORT=3000
FRONTEND_WEB_HOST_PORT=8081

BACKEND_IMAGE_NAME=ghcr.io/your-org/containermaster-backend
BACKEND_IMAGE_TAG=latest
FRONTEND_IMAGE_NAME=ghcr.io/your-org/containermaster-frontend-web
FRONTEND_IMAGE_TAG=latest

APP_VERSION=0.1.0
APP_COMMIT_SHA=local
LOG_FORMAT=json
ENABLE_ACCESS_LOGS=true

BACKEND_HEALTH_URL=http://localhost:3000/health
FRONTEND_HEALTH_URL=http://localhost:8081/
HEALTHCHECK_TIMEOUT_SECONDS=180
HEALTHCHECK_INTERVAL_SECONDS=3
